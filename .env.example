# ============================================
# VARIÁVEIS DE AMBIENTE (VERCEL)
# ============================================
# Configure estas variáveis no painel do Vercel:
# https://vercel.com/[seu-projeto]/settings/environment-variables

# Connection string do MongoDB Atlas
MONGODB_URI=mongodb+srv://usuario:senha@cluster.mongodb.net/?retryWrites=true&w=majority

# Nome do banco de dados
MONGODB_DB_NAME=twitch-votacao

# Token secreto para acessar rotas protegidas (o bot envia este token)
ADMIN_TOKEN=seu_token_secreto_aqui

# TMDB API Key (Read Access Token)
TMDB_API_KEY=seu_tmdb_read_access_token

# ============================================
# VARIÁVEIS DE AMBIENTE (BOT - .env local)
# ============================================
# Configure no arquivo backend/.env do seu PC:

# TWITCH_USERNAME=NomeDoBotNaTwitch
# TWITCH_OAUTH_TOKEN=oauth:seu_token_aqui
# TWITCH_CHANNEL=seu_canal
# API_BASE_URL=https://seu-app.vercel.app
# ADMIN_TOKEN=mesmo_token_do_vercel
